@page "/pipeline-runs"
@using datntdev.Fabric.PipelineRunsViewer.Services
@using datntdev.Fabric.PipelineRunsViewer.Models
@using System.Text
@using System.Text.Json
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web.Virtualization
@inject FabricApiService FabricApiService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<PageTitle>Pipeline Runs Viewer</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h3 class="mb-0">Fabric Pipeline Run Viewer</h3>
                    <button class="btn btn-light btn-sm" @onclick="ToggleInputPanel">
                        @if (showInputPanel)
                        {
                            <span>▲ Hide Inputs</span>
                        }
                        else
                        {
                            <span>▼ Show Inputs</span>
                        }
                    </button>
                </div>
                
                @if (showInputPanel)
                {
                    <div class="card-body">
                        <form @onsubmit="HandleSubmit">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="workspaceId" class="form-label">Workspace ID</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="workspaceId" 
                                           @bind="workspaceId" 
                                           placeholder="Enter Workspace ID (GUID)"
                                           disabled="@isLoading"
                                           required />
                                    <div class="form-text">The GUID of your Fabric workspace</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="pipelineRunId" class="form-label">Fabric Pipeline Run Id</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="pipelineRunId" 
                                           @bind="pipelineRunId" 
                                           placeholder="Enter Pipeline Run ID"
                                           disabled="@isLoading"
                                           required />
                                    <div class="form-text">Enter the Fabric Pipeline Run ID to view activity run details.</div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="lastUpdatedAfter" class="form-label">Last Updated After</label>
                                    <input type="datetime-local" 
                                           class="form-control" 
                                           id="lastUpdatedAfter" 
                                           @bind="lastUpdatedAfter" 
                                           disabled="@isLoading" />
                                    <div class="form-text">Optional: Filter activities updated after this date</div>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="lastUpdatedBefore" class="form-label">Last Updated Before</label>
                                    <input type="datetime-local" 
                                           class="form-control" 
                                           id="lastUpdatedBefore" 
                                           @bind="lastUpdatedBefore" 
                                           disabled="@isLoading" />
                                    <div class="form-text">Optional: Filter activities updated before this date</div>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Loading...</span>
                                }
                                else
                                {
                                    <span>Submit</span>
                                }
                            </button>
                        </form>

                        <hr class="my-4" />

                        <div class="mb-3">
                            <label for="fileUpload" class="form-label">Or Import JSON File</label>
                            <InputFile id="fileUpload" OnChange="HandleFileSelected" class="form-control" accept=".json" />
                            <div class="form-text">Upload a previously downloaded activity runs JSON file</div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger m-3" role="alert">
                        <h5 class="alert-heading">Error!</h5>
                        <p>@errorMessage</p>
                    </div>
                }

                @if (parsedActivityRuns != null && parsedActivityRuns.Any())
                {
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h5>Activity Runs (@GetFilteredActivities().Count() of @activityRunCount total)</h5>
                            <button class="btn btn-success" @onclick="DownloadJson">
                                <i class="bi bi-download"></i> Download JSON
                            </button>
                        </div>
                        
                        <!-- Tabs -->
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link @(activeTab == "table" ? "active" : "")" 
                                        @onclick='() => activeTab = "table"' 
                                        type="button">
                                    Table View
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link @(activeTab == "json" ? "active" : "")" 
                                        @onclick='() => activeTab = "json"' 
                                        type="button">
                                    JSON Preview
                                </button>
                            </li>
                        </ul>

                        <div class="tab-content mt-3">
                            @if (activeTab == "table")
                            {
                                <!-- Filters and Search -->
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label for="searchText" class="form-label">Search Activity Name</label>
                                        <input type="text" 
                                               class="form-control" 
                                               id="searchText" 
                                               @bind="searchText" 
                                               @bind:event="oninput"
                                               placeholder="Type to search..." />
                                    </div>
                                    <div class="col-md-3">
                                        <label for="statusFilter" class="form-label">Filter by Status</label>
                                        <select class="form-select" id="statusFilter" @bind="statusFilter">
                                            <option value="">All Statuses</option>
                                            <option value="Succeeded">Succeeded</option>
                                            <option value="Failed">Failed</option>
                                            <option value="InProgress">In Progress</option>
                                            <option value="Queued">Queued</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="sortBy" class="form-label">Sort By</label>
                                        <select class="form-select" id="sortBy" @bind="sortBy">
                                            <option value="StartTimeAsc">Start Time (Oldest First)</option>
                                            <option value="StartTimeDesc">Start Time (Newest First)</option>
                                            <option value="DurationAsc">Duration (Shortest First)</option>
                                            <option value="DurationDesc">Duration (Longest First)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-2 d-flex align-items-end">
                                        <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                                            Clear Filters
                                        </button>
                                    </div>
                                </div>

                                <!-- Virtual Scrolling Table -->
                                <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                                    <table class="table table-striped table-hover">
                                        <thead class="table-dark sticky-top">
                                            <tr>
                                                <th>Status</th>
                                                <th>Activity Name</th>
                                                <th>Type</th>
                                                <th>Start Time</th>
                                                <th>End Time</th>
                                                <th>Duration</th>
                                                <th>Input</th>
                                                <th>Output</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <Virtualize Items="@GetFilteredActivities().ToList()" Context="activity">
                                                <tr>
                                                    <td>
                                                        <span class="@activity.GetStatusClass() fw-bold">
                                                            @activity.GetStatusIcon() @activity.Status
                                                        </span>
                                                    </td>
                                                    <td>@activity.ActivityName</td>
                                                    <td><span class="badge bg-info">@activity.ActivityType</span></td>
                                                    <td>@activity.ActivityRunStart?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                    <td>@activity.ActivityRunEnd?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                                    <td>@activity.GetFormattedDuration()</td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-primary" 
                                                                @onclick="() => ShowInputModal(activity)">
                                                            More Details
                                                        </button>
                                                    </td>
                                                    <td>
                                                        <button class="btn btn-sm btn-outline-success" 
                                                                @onclick="() => ShowOutputModal(activity)">
                                                            More Details
                                                        </button>
                                                    </td>
                                                </tr>
                                            </Virtualize>
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else if (activeTab == "json")
                            {
                                <div class="card">
                                    <div class="card-header bg-secondary text-white">
                                        JSON Preview
                                    </div>
                                    <div class="card-body p-0">
                                        <pre class="mb-0 p-3" style="max-height: 500px; overflow-y: auto; background-color: #f8f9fa;"><code>@jsonData</code></pre>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Input Modal -->
@if (showInputModal && selectedActivity != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Input Details - @selectedActivity.ActivityName</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseInputModal"></button>
                </div>
                <div class="modal-body">
                    <pre class="p-3" style="background-color: #f8f9fa; border-radius: 5px;"><code>@FormatJson(selectedActivity.Input)</code></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseInputModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Output Modal -->
@if (showOutputModal && selectedActivity != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Output Details - @selectedActivity.ActivityName</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseOutputModal"></button>
                </div>
                <div class="modal-body">
                    <pre class="p-3" style="background-color: #f8f9fa; border-radius: 5px;"><code>@FormatJson(selectedActivity.Output)</code></pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseOutputModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string workspaceId = string.Empty;
    private string pipelineRunId = string.Empty;
    private DateTime? lastUpdatedAfter;
    private DateTime? lastUpdatedBefore;
    private string jsonData = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private int activityRunCount = 0;
    private List<object>? activityRuns;
    private List<ActivityRun>? parsedActivityRuns;
    private string activeTab = "table";
    private bool showInputModal = false;
    private bool showOutputModal = false;
    private ActivityRun? selectedActivity;
    private bool showInputPanel = true;
    
    // Filter and Sort states
    private string searchText = string.Empty;
    private string statusFilter = string.Empty;
    private string sortBy = "StartTimeAsc";

    private void ToggleInputPanel()
    {
        showInputPanel = !showInputPanel;
    }

    private void ClearFilters()
    {
        searchText = string.Empty;
        statusFilter = string.Empty;
        sortBy = "StartTimeAsc";
    }

    private IEnumerable<ActivityRun> GetFilteredActivities()
    {
        if (parsedActivityRuns == null)
            return Enumerable.Empty<ActivityRun>();

        var filtered = parsedActivityRuns.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            filtered = filtered.Where(a => 
                a.ActivityName?.Contains(searchText, StringComparison.OrdinalIgnoreCase) == true);
        }

        // Apply status filter
        if (!string.IsNullOrWhiteSpace(statusFilter))
        {
            filtered = filtered.Where(a => 
                a.Status?.Equals(statusFilter, StringComparison.OrdinalIgnoreCase) == true);
        }

        // Apply sort
        filtered = sortBy switch
        {
            "StartTimeAsc" => filtered.OrderBy(a => a.ActivityRunStart ?? DateTime.MaxValue),
            "StartTimeDesc" => filtered.OrderByDescending(a => a.ActivityRunStart ?? DateTime.MinValue),
            "DurationAsc" => filtered.OrderBy(a => a.DurationInMs ?? long.MaxValue),
            "DurationDesc" => filtered.OrderByDescending(a => a.DurationInMs ?? 0),
            _ => filtered
        };

        return filtered;
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;
        jsonData = string.Empty;
        isLoading = true;
        activityRunCount = 0;

        try
        {
            activityRuns = await FabricApiService.GetActivityRunsAsync(workspaceId, pipelineRunId, lastUpdatedAfter, lastUpdatedBefore);
            activityRunCount = activityRuns.Count;
            jsonData = FabricApiService.SerializeToJson(activityRuns);
            ParseActivityRuns();
            showInputPanel = false; // Collapse after successful fetch
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to fetch activity runs: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        errorMessage = string.Empty;
        jsonData = string.Empty;
        parsedActivityRuns = null;

        try
        {
            var file = e.File;
            if (file.ContentType != "application/json" && !file.Name.EndsWith(".json"))
            {
                errorMessage = "Please select a valid JSON file.";
                return;
            }

            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB max
            using var reader = new StreamReader(stream);
            jsonData = await reader.ReadToEndAsync();

            ParseActivityRuns();
            activityRunCount = parsedActivityRuns?.Count ?? 0;
            showInputPanel = false; // Collapse after successful import
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to read file: {ex.Message}";
        }
    }

    private void ParseActivityRuns()
    {
        try
        {
            if (string.IsNullOrEmpty(jsonData))
                return;

            parsedActivityRuns = JsonSerializer.Deserialize<List<ActivityRun>>(jsonData, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to parse JSON: {ex.Message}";
        }
    }

    private async Task DownloadJson()
    {
        if (string.IsNullOrEmpty(jsonData) || parsedActivityRuns == null || !parsedActivityRuns.Any())
            return;

        // Get pipeline name from first activity run (all should have the same pipeline)
        var pipelineName = parsedActivityRuns.First().PipelineName ?? "pipeline";
        
        // Get the earliest start time
        var earliestStart = parsedActivityRuns
            .Where(a => a.ActivityRunStart.HasValue)
            .OrderBy(a => a.ActivityRunStart)
            .FirstOrDefault()?.ActivityRunStart;

        var startTimeStr = earliestStart?.ToString("yyyyMMddHHmmss") ?? DateTime.Now.ToString("yyyyMMddHHmmss");
        
        // Format: <pipeline_name>_<start_time>.json
        var fileName = $"{SanitizeFileName(pipelineName)}_{startTimeStr}.json";
        var bytes = Encoding.UTF8.GetBytes(jsonData);
        var base64 = Convert.ToBase64String(bytes);

        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, base64);
    }

    private string SanitizeFileName(string fileName)
    {
        // Remove invalid file name characters
        var invalidChars = Path.GetInvalidFileNameChars();
        return string.Join("_", fileName.Split(invalidChars, StringSplitOptions.RemoveEmptyEntries)).TrimEnd('.');
    }

    private void ShowInputModal(ActivityRun activity)
    {
        selectedActivity = activity;
        showInputModal = true;
    }

    private void ShowOutputModal(ActivityRun activity)
    {
        selectedActivity = activity;
        showOutputModal = true;
    }

    private void CloseInputModal()
    {
        showInputModal = false;
        selectedActivity = null;
    }

    private void CloseOutputModal()
    {
        showOutputModal = false;
        selectedActivity = null;
    }

    private string FormatJson(object? obj)
    {
        if (obj == null)
            return "{}";

        try
        {
            // If obj is JsonElement, handle it specially
            if (obj is JsonElement element)
            {
                // If the JsonElement is a string, try to parse it as JSON
                if (element.ValueKind == JsonValueKind.String)
                {
                    var stringValue = element.GetString();
                    if (!string.IsNullOrWhiteSpace(stringValue))
                    {
                        try
                        {
                            // Try to parse the string content as JSON
                            using var doc = JsonDocument.Parse(stringValue);
                            return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions
                            {
                                WriteIndented = true
                            });
                        }
                        catch
                        {
                            // If it's not valid JSON, return the string as-is
                            return stringValue;
                        }
                    }
                }
                
                // Otherwise, serialize the JsonElement directly
                return JsonSerializer.Serialize(element, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
            }

            // If obj is a string, try to parse it as JSON first
            if (obj is string jsonString)
            {
                if (string.IsNullOrWhiteSpace(jsonString))
                    return "{}";

                try
                {
                    // Try to parse the string as JSON
                    using var doc = JsonDocument.Parse(jsonString);
                    return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions
                    {
                        WriteIndented = true
                    });
                }
                catch
                {
                    // If it's not valid JSON, return the string as-is
                    return jsonString;
                }
            }

            // Otherwise, serialize the object
            return JsonSerializer.Serialize(obj, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            // If everything fails, return the string representation
            return obj.ToString() ?? "{}";
        }
    }
}

