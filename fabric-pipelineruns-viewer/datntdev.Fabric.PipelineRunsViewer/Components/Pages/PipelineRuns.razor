@page "/pipeline-runs"

<PageTitle>Pipeline Runs Viewer</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Fabric Pipeline Run Viewer</h3>
                </div>
                <div class="card-body">
                    <form @onsubmit="HandleSubmit">
                        <div class="mb-3">
                            <label for="pipelineRunId" class="form-label">Fabric Pipeline Run Id</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="pipelineRunId" 
                                   @bind="pipelineRunId" 
                                   placeholder="Enter Pipeline Run ID"
                                   required />
                            <div class="form-text">Enter the Fabric Pipeline Run ID to view details.</div>
                        </div>
                        <button type="submit" class="btn btn-primary">Submit</button>
                    </form>

                    @if (!string.IsNullOrEmpty(submittedId))
                    {
                        <div class="alert alert-success mt-4" role="alert">
                            <h5 class="alert-heading">Submitted!</h5>
                            <p>Pipeline Run ID: <strong>@submittedId</strong></p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string pipelineRunId = string.Empty;
    private string submittedId = string.Empty;

    private void HandleSubmit()
    {
        submittedId = pipelineRunId;
        // Add your logic here to fetch and display pipeline run details
    }
}
